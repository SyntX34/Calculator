{
  "build": {
    "beforeDevCommand": "cd .. && php -S localhost:8000",
    "devPath": "http://localhost:8000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Calculator Hub",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.calculator-hub.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png"
      ],
      "category": "Utility",
      "shortDescription": "All-in-One Calculator",
      "longDescription": "A powerful, feature-rich calculator with 12 different modes.",
      "copyright": "© 2026 Samir Neupane",
      "windows": {
        "wix": null,
        "nsis": {
          "installMode": "currentUser"
        }
      },
      "macOS": {
        "minimumSystemVersion": "10.15"
      },
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Calculator Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 320,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
